<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Smart Campus API</display-name>

    <!-- Jersey Servlet - handles all /api/v1/* requests -->
    <servlet>
        <servlet-name>JerseyServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <!-- Point Jersey directly at our Application subclass (most reliable method) -->
        <init-param>
            <param-name>jakarta.ws.rs.Application</param-name>
            <param-value>com.smartcampus.SmartCampusApplication</param-value>
        </init-param>
        <!-- Also tell Jersey to scan for @Provider classes (filters, mappers) -->
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>JerseyServlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

    <!-- CORS Filter - allows the frontend (served on same origin) to call the API -->
    <filter>
        <filter-name>CORSFilter</filter-name>
        <filter-class>com.smartcampus.filter.CORSFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CORSFilter</filter-name>
        <url-pattern>/api/v1/*</url-pattern>
    </filter-mapping>

    <!-- Default servlet serves static files (index.html, css, js) -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
